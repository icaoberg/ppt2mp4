Bootstrap: docker
From: ubuntu:22.04

%labels
    Author Ivan Cao-Berg
    Group Biomedical Applications Group
    Center Pittsburgh Supercomputing Center
    Description PPT to MP4 converter with AI voice narration

%post
    export DEBIAN_FRONTEND=noninteractive

    # System packages
    apt-get update && apt-get install -y \
        python3 \
        python3-pip \
        libreoffice \
        poppler-utils \
        ffmpeg \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Python packages
    pip3 install --no-cache-dir \
        python-pptx \
        edge-tts \
        "moviepy<2" \
        pdf2image \
        pillow

    # Install the script
    mkdir -p /opt/ppt2mp4
    cp /tmp/ppt2mp4.py /opt/ppt2mp4/ppt2mp4.py
    chmod +x /opt/ppt2mp4/ppt2mp4.py

%files
    ppt2mp4.py /tmp/ppt2mp4.py

%environment
    export PATH=/opt/ppt2mp4:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec python3 /opt/ppt2mp4/ppt2mp4.py "$@"

%help
    PPT to Video Converter with AI voice narration.

    Usage:
        singularity run ppt2mp4.sif <presentation.pptx> [options]

    Options:
        --voice NAME       Edge TTS voice name (default: en-US-ChristopherNeural)
        --silent SECONDS   Duration for slides without notes (default: 3.0)
        --output PATH      Output MP4 path (default: same name as input)
        --author NAME      Author name for video metadata
        --group NAME       Group name for video metadata
        --center NAME      Center name for video metadata
        --copyright TEXT   Copyright string for video metadata

    Example:
        singularity run ppt2mp4.sif presentation.pptx --voice en-GB-RyanNeural

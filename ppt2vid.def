Bootstrap: docker
From: ubuntu:22.04

%labels
    Author icaoberg
    Group Biomedical Applications Group
    Center Pittsburgh Supercomputing Center
    Description PPT to video converter with AI voice narration

%files
    ppt2vid.py /tmp/ppt2vid.py

%post
    export DEBIAN_FRONTEND=noninteractive

    # System packages
    apt-get update && apt-get install -y \
        python3 \
        python3-pip \
        libreoffice \
        poppler-utils \
        ffmpeg \
        libavcodec-extra \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Python packages
    pip3 install --no-cache-dir \
        python-pptx \
        edge-tts \
        "moviepy<2" \
        pdf2image \
        pillow

    # Install the script
    mkdir -p /opt/ppt2vid
    cp /tmp/ppt2vid.py /opt/ppt2vid/ppt2vid.py
    chmod +x /opt/ppt2vid/ppt2vid.py

%environment
    export PATH=/opt/ppt2vid:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec python3 /opt/ppt2vid/ppt2vid.py "$@"

%help
    PPT to Video Converter with AI voice narration.

    Usage:
        singularity run ppt2vid.sif <presentation.pptx> [options]

    Options:
        --voice NAME       Edge TTS voice name (default: en-US-ChristopherNeural)
        --silent SECONDS   Duration for slides without notes (default: 3.0)
        --output PATH      Output video path. Format is selected by file extension:
                             .mp4 / .m4v   H.264 + AAC      (default)
                             .ogv / .oggv  Theora + Vorbis
                             .avi          H.264 + MP3
                             .wmv          WMV2 + WMA2
                           Defaults to the input filename with a .mp4 extension.
        --author NAME      Author name for video metadata
        --group NAME       Group name for video metadata
        --center NAME      Center name for video metadata
        --copyright TEXT   Copyright string for video metadata

    Examples:
        singularity run ppt2vid.sif presentation.pptx
        singularity run ppt2vid.sif presentation.pptx --output ~/Videos/talk.mp4
        singularity run ppt2vid.sif presentation.pptx --output talk.wmv
        singularity run ppt2vid.sif presentation.pptx --voice en-GB-RyanNeural --silent 5
        singularity run ppt2vid.sif presentation.pptx --author "Jane Smith" --group "Research Lab"
